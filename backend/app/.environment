# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=admin1234
MINIO_SECURE=False
MINIO_BUCKET=video-analytics
MINIO_FOLDER_VIDEOS=videos
MINIO_FOLDER_ANALYTIC_VIDEOS=analytic-videos
MINIO_FOLDER_FRAGMENTS=fragments

# App Settings
DEBUG=True
FRAMES_PER_SECOND=10
DETECTION_CONFIDENCE_THRESHOLD=0.35
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.5
GROUNDING_DINO_MODEL_PATH=models/classifier_model
MAX_VIDEO_SIZE_MB=500
UPLOAD_DIR=data/uploads
DEFAULT_GAP_THRESHOLD=0.5